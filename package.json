{
  "name": "paqueteria-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:kill": "node scripts/kill-dev-server.mjs",
    "dev:open": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-server.ps1",
    "up": "node scripts/dev-up.mjs",
    "phone": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-tunnel.ps1",
    "preview": "powershell -ExecutionPolicy Bypass -File scripts/start-public-tunnel.ps1",
    "dev:up": "npm run up",
    "host:dev": "npm run phone",
    "host:pc": "npm run preview",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:code": "eslint --max-warnings=0 && knip && npm run check:duplicates",
    "check:duplicates": "jscpd src --min-lines 5 --min-tokens 50 --ignore \"**/*.test.ts,**/*.eval.test.ts\" --threshold 3 --reporters threshold --no-tips",
    "db:check": "node scripts/check-schema.mjs",
    "db:apply": "node scripts/apply-migrations.mjs",
    "db:inspect": "node scripts/db-inspect.mjs",
    "db:list-users": "node scripts/db-list-users.mjs",
    "db:reset-passwords": "node scripts/db-reset-passwords.mjs",
    "db:delete-users": "node scripts/db-delete-all-users.mjs",
    "db:repair-plan-limits": "node scripts/repair-plan-limits.mjs",
    "db:rename-platform-org": "node scripts/rename-platform-org.mjs",
    "db:add-box-sizes": "node scripts/add-inventory-box-sizes.mjs",
    "db:wipe": "node scripts/wipe-database.mjs",
    "db:restore-owner": "node scripts/restore-platform-owner.mjs",
    "db:seed:senders": "node scripts/seed-scgs-senders.mjs",
    "db:seed:mx-recipients": "node scripts/seed-scgs-mexico-recipients.mjs",
    "db:seed:mx-products": "node scripts/seed-scgs-mexico-products.mjs",
    "db:seed:demo-catalog": "node scripts/seed-scgs-demo-catalog.mjs",
    "db:seed:more-senders": "node scripts/seed-scgs-more-senders.mjs",
    "db:seed:scgs-demo": "node scripts/seed-scgs-senders.mjs && node scripts/add-inventory-box-sizes.mjs && node scripts/seed-scgs-demo-catalog.mjs",
    "db:seed:logistics-workday": "node scripts/seed-logistics-workday.mjs",
    "db:seed:invoice-scenarios": "node scripts/seed-invoice-scenarios.mjs",
    "db:seed:envios-pending": "node scripts/seed-envios-pending.mjs",
    "db:reset:catalog": "node scripts/reset-scgs-catalog.mjs",
    "db:reset:baseline": "node scripts/reset-app-to-baseline.mjs",
    "db:reset:scgs": "node scripts/reset-scgs-demo-data.mjs",
    "db:clear:sales": "node scripts/clear-sales-history.mjs",
    "db:local:reset": "npx supabase db reset",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "env:local": "powershell -ExecutionPolicy Bypass -File scripts/use-local-env.ps1",
    "codegen:dial-codes": "node scripts/generate-dial-codes.mjs",
    "test": "npm run test:gate && npm run test:eval",
    "test:gate": "node scripts/run-tests.mjs gate",
    "test:eval": "node scripts/run-tests.mjs eval",
    "test:platform-auth": "node scripts/test-platform-auth-flow.mjs",
    "test:matrix-initialization": "node scripts/test-matrix-initialization.mjs",
    "test:business-db": "node scripts/test-business-model.mjs",
    "test:commercial-db": "node scripts/test-commercial-config.mjs",
    "test:sms": "node scripts/test-sms-flow.mjs",
    "export:chatgpt": "node scripts/export-chatgpt-folder.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.106.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.10",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "fake-indexeddb": "^6.2.4",
    "jscpd": "^5.0.12",
    "knip": "^6.26.0",
    "pg": "^8.21.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
